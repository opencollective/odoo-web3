# Environment: "production" or "sandbox" (default: sandbox)
# Controls which blockchain (gnosis vs chiado) and Monerium environment to use.
ENV=sandbox

# Monerium API credentials (for SEPA metadata enrichment during sync)
MONERIUM_CLIENT_ID=
MONERIUM_CLIENT_SECRET=

# Encrypted private key for signing Safe transactions.
# Generate with: bun run scripts/encrypt-key.ts
# On server start, submit the passphrase via POST /api/unlock to decrypt into memory.
# The key is never stored in plaintext — only the encrypted blob lives in the env var.
PRIVATE_KEY_ENCRYPTED=

# Odoo credentials (optional — can be set in the browser UI instead, stored in localStorage)
# ODOO_URL=https://yourcompany.odoo.com
# ODOO_DATABASE=your_database
# ODOO_USERNAME=your_username
# ODOO_PASSWORD=your_password

# Etherscan API key (optional — Blockscout endpoints for Gnosis/Chiado don't need one)
# ETHEREUM_ETHERSCAN_API_KEY=

# Safe contract address (only needed for batch payment signing)
# SAFE_ADDRESS=0x...

# Override the RPC URL for Safe operations (defaults to public Gnosis/Chiado RPC)
# SAFE_RPC_URL=https://rpc.gnosischain.com

# Public address of the signing key (optional). Lets the UI show the signer
# address even while the keystore is locked. Derived automatically once unlocked.
# SIGNER_ADDRESS=0x...

# Required to collect signatures for multisig (M-of-N) Safes via the Safe
# Transaction Service. Get one from the Safe developer portal.
# SAFE_API_KEY=
# Or point at a self-hosted / non-default Safe Transaction Service instead of
# providing an API key (e.g. for Chiado).
# SAFE_TX_SERVICE_URL=

# --- Test-only: tests/monerium-safe-order.test.ts (Monerium sandbox + Chiado) ---
# Reproduces that an order works for a 1-of-N Safe but is rejected for an M-of-N
# Safe. The test skips unless these are set. Uses MONERIUM_CLIENT_ID/SECRET above
# (sandbox credentials) and SAFE_RPC_URL (Chiado RPC).
# TEST_SAFE_1OFN=0x...          # a 1-of-N Safe on Chiado linked to the Monerium account
# TEST_SAFE_2OFN=0x...          # a 2-of-N Safe on Chiado linked to the Monerium account
# TEST_OWNER_KEY_1=0x...        # owner key: signs the 1-of-N and is the 1st signer of the 2-of-N
# TEST_OWNER_KEY_2=0x...        # 2nd owner key of the 2-of-N Safe
# TEST_IBAN=                    # destination IBAN for the redeem order
# TEST_COMPANY_NAME=Test Co     # counterpart name (optional, default "Test Co")
